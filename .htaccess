<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Set base URL - sesuaikan dengan lokasi folder proyek Anda
    # Jika di root: RewriteBase /
    # Jika di subfolder: RewriteBase /nama_folder/
    RewriteBase /

    # Redirect langsung ke index.php untuk semua request
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [QSA,L]
</IfModule>

# Jika mod_rewrite tidak aktif
<IfModule !mod_rewrite.c>
    ErrorDocument 404 /index.php
</IfModule>